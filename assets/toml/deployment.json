{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DeploymentToml",
  "type": "object",
  "properties": {
    "activity_exec": {
      "type": "array",
      "default": [],
      "items": {
        "$ref": "#/$defs/ActivityExecComponentConfigToml"
      }
    },
    "activity_external": {
      "type": "array",
      "default": [],
      "items": {
        "$ref": "#/$defs/ActivityExternalComponentConfigToml"
      }
    },
    "activity_js": {
      "type": "array",
      "default": [],
      "items": {
        "$ref": "#/$defs/ActivityJsComponentConfigToml"
      }
    },
    "activity_stub": {
      "type": "array",
      "default": [],
      "items": {
        "$ref": "#/$defs/ActivityStubComponentConfigToml"
      }
    },
    "activity_wasm": {
      "type": "array",
      "default": [],
      "items": {
        "$ref": "#/$defs/ActivityWasmComponentConfigToml"
      }
    },
    "cron": {
      "type": "array",
      "default": [],
      "items": {
        "$ref": "#/$defs/CronComponentConfigToml"
      }
    },
    "webhook_endpoint_js": {
      "type": "array",
      "default": [],
      "items": {
        "$ref": "#/$defs/WebhookJsComponentConfigToml"
      }
    },
    "webhook_endpoint_wasm": {
      "type": "array",
      "default": [],
      "items": {
        "$ref": "#/$defs/WebhookWasmComponentConfigToml"
      }
    },
    "workflow_js": {
      "type": "array",
      "default": [],
      "items": {
        "$ref": "#/$defs/WorkflowJsComponentConfigToml"
      }
    },
    "workflow_wasm": {
      "type": "array",
      "default": [],
      "items": {
        "$ref": "#/$defs/WorkflowWasmComponentConfigToml"
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "ActivityExecComponentConfigToml": {
      "type": "object",
      "properties": {
        "component_digest": {
          "description": "Override the auto-computed component digest used for locking.",
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "cwd": {
          "description": "Working directory for the child process. Supports `${DEPLOYMENT_DIR}` expansion.\nDefaults to the server's working directory.",
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "env_vars": {
          "type": "array",
          "default": [],
          "items": {
            "$ref": "#/$defs/EnvVarConfig"
          }
        },
        "exec": {
          "$ref": "#/$defs/ExecConfigToml",
          "default": {
            "batch_size": 5,
            "lock_expiry": {
              "seconds": 1
            },
            "locking_strategy": null,
            "tick_sleep": {
              "milliseconds": 200
            }
          }
        },
        "ffqn": {
          "type": "string"
        },
        "forward_stderr": {
          "$ref": "#/$defs/ComponentStdOutputToml",
          "default": "db"
        },
        "forward_stdout": {
          "$ref": "#/$defs/ComponentStdOutputToml",
          "default": "db"
        },
        "logs_store_min_level": {
          "$ref": "#/$defs/LogLevelToml",
          "default": "debug"
        },
        "max_output_bytes": {
          "description": "Maximum bytes collected from stdout to form the response.\nExceeding the limit fails the execution.\nNot used when return_type is result (default), since the response carries no data.",
          "type": "integer",
          "format": "uint64",
          "default": 1024,
          "minimum": 0
        },
        "max_retries": {
          "type": "integer",
          "format": "uint32",
          "default": 5,
          "minimum": 0
        },
        "name": {
          "description": "Component name. Optional when `ffqn` is specified — defaults to `{ifc_name}.{function_name}`.",
          "anyOf": [
            {
              "$ref": "#/$defs/ConfigName"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "params": {
          "description": "Custom parameters for the exec activity.\nEach entry has a `name` and a WIT `type` (e.g. `string`, `u32`, `list<string>`).",
          "type": "array",
          "default": [],
          "items": {
            "$ref": "#/$defs/JsParamToml"
          }
        },
        "program": {
          "description": "Program specification. Exactly one of `external`, `inline`, or `include`.",
          "$ref": "#/$defs/ExecProgramToml"
        },
        "retry_exp_backoff": {
          "$ref": "#/$defs/DurationConfig",
          "default": {
            "milliseconds": 100
          }
        },
        "return_type": {
          "description": "WIT return type. Defaults to `result`.",
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "secrets": {
          "description": "Secrets pushed to stdin. See `ExecSecretsToml`.",
          "anyOf": [
            {
              "$ref": "#/$defs/ExecSecretsToml"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "additionalProperties": false,
      "required": [
        "program",
        "ffqn"
      ]
    },
    "ActivityExternalComponentConfigToml": {
      "anyOf": [
        {
          "$ref": "#/$defs/ActivityExternalFileConfigToml"
        },
        {
          "$ref": "#/$defs/ActivityStubExtInlineConfigToml"
        }
      ]
    },
    "ActivityExternalFileConfigToml": {
      "type": "object",
      "properties": {
        "component_digest": {
          "description": "Override the auto-computed component digest used for locking.\nIf set, this value is used instead of the content digest of the WASM file.",
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "location": {
          "type": "string"
        },
        "name": {
          "$ref": "#/$defs/ConfigName"
        }
      },
      "additionalProperties": false,
      "required": [
        "name",
        "location"
      ]
    },
    "ActivityJsComponentConfigToml": {
      "type": "object",
      "properties": {
        "allowed_host": {
          "description": "Allowed outgoing HTTP hosts with optional method restrictions and secrets.",
          "type": "array",
          "default": [],
          "items": {
            "$ref": "#/$defs/AllowedHostToml"
          }
        },
        "component_digest": {
          "description": "Override the auto-computed component digest used for locking.\nIf set, this value is used instead of the digest derived from the JS source, ffqn, and params.",
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "content_digest": {
          "description": "Content digest of the JS source file.",
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "env_vars": {
          "type": "array",
          "default": [],
          "items": {
            "$ref": "#/$defs/EnvVarConfig"
          }
        },
        "exec": {
          "$ref": "#/$defs/ExecConfigToml",
          "default": {
            "batch_size": 5,
            "lock_expiry": {
              "seconds": 1
            },
            "locking_strategy": null,
            "tick_sleep": {
              "milliseconds": 200
            }
          }
        },
        "ffqn": {
          "type": "string"
        },
        "forward_stderr": {
          "$ref": "#/$defs/ComponentStdOutputToml",
          "default": "db"
        },
        "forward_stdout": {
          "$ref": "#/$defs/ComponentStdOutputToml",
          "default": "db"
        },
        "location": {
          "description": "Location of the JavaScript source file.\nSupports local file paths and OCI registry references (`oci://...`).",
          "$ref": "#/$defs/JsLocationToml"
        },
        "logs_store_min_level": {
          "$ref": "#/$defs/LogLevelToml",
          "default": "debug"
        },
        "max_retries": {
          "type": "integer",
          "format": "uint32",
          "default": 5,
          "minimum": 0
        },
        "name": {
          "description": "Component name. Optional when `ffqn` is specified — defaults to `{ifc_name}.{function_name}`.",
          "anyOf": [
            {
              "$ref": "#/$defs/ConfigName"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "params": {
          "description": "Custom parameters for the JS function.\nEach entry has a `name` and a WIT `type` (e.g. `string`, `u32`, `list<string>`).\nDefaults to no parameters.",
          "type": "array",
          "default": [],
          "items": {
            "$ref": "#/$defs/JsParamToml"
          }
        },
        "retry_exp_backoff": {
          "$ref": "#/$defs/DurationConfig",
          "default": {
            "milliseconds": 100
          }
        },
        "return_type": {
          "description": "WIT return type. Defaults to `result`.\nMust be `result<T, string>` — the error type must be `string` since JS throws strings.",
          "type": [
            "string",
            "null"
          ],
          "default": null
        }
      },
      "additionalProperties": false,
      "required": [
        "location",
        "ffqn"
      ]
    },
    "ActivityStubComponentConfigToml": {
      "anyOf": [
        {
          "$ref": "#/$defs/ActivityStubFileConfigToml"
        },
        {
          "$ref": "#/$defs/ActivityStubExtInlineConfigToml"
        }
      ]
    },
    "ActivityStubExtInlineConfigToml": {
      "type": "object",
      "properties": {
        "ffqn": {
          "type": "string"
        },
        "name": {
          "description": "Component name. Optional — defaults to `{ifc_name}.{function_name}` from `ffqn`.",
          "anyOf": [
            {
              "$ref": "#/$defs/ConfigName"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "params": {
          "type": [
            "array",
            "null"
          ],
          "default": null,
          "items": {
            "$ref": "#/$defs/JsParamToml"
          }
        },
        "return_type": {
          "type": [
            "string",
            "null"
          ],
          "default": null
        }
      },
      "additionalProperties": false,
      "required": [
        "ffqn"
      ]
    },
    "ActivityStubFileConfigToml": {
      "type": "object",
      "properties": {
        "location": {
          "type": "string"
        },
        "name": {
          "$ref": "#/$defs/ConfigName"
        }
      },
      "additionalProperties": false,
      "required": [
        "name",
        "location"
      ]
    },
    "ActivityWasmComponentConfigToml": {
      "type": "object",
      "properties": {
        "allowed_host": {
          "description": "Allowed outgoing HTTP hosts with optional method restrictions and secrets.",
          "type": "array",
          "default": [],
          "items": {
            "$ref": "#/$defs/AllowedHostToml"
          }
        },
        "component_digest": {
          "description": "Override the auto-computed component digest used for locking.\nIf set, this value is used instead of the content digest of the WASM file.",
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "env_vars": {
          "type": "array",
          "default": [],
          "items": {
            "$ref": "#/$defs/EnvVarConfig"
          }
        },
        "exec": {
          "$ref": "#/$defs/ExecConfigToml",
          "default": {
            "batch_size": 5,
            "lock_expiry": {
              "seconds": 1
            },
            "locking_strategy": null,
            "tick_sleep": {
              "milliseconds": 200
            }
          }
        },
        "forward_stderr": {
          "$ref": "#/$defs/ComponentStdOutputToml",
          "default": "db"
        },
        "forward_stdout": {
          "$ref": "#/$defs/ComponentStdOutputToml",
          "default": "db"
        },
        "location": {
          "type": "string"
        },
        "logs_store_min_level": {
          "$ref": "#/$defs/LogLevelToml",
          "default": "debug"
        },
        "max_retries": {
          "type": "integer",
          "format": "uint32",
          "default": 5,
          "minimum": 0
        },
        "name": {
          "$ref": "#/$defs/ConfigName"
        },
        "retry_exp_backoff": {
          "$ref": "#/$defs/DurationConfig",
          "default": {
            "milliseconds": 100
          }
        }
      },
      "additionalProperties": false,
      "required": [
        "name",
        "location"
      ]
    },
    "AllowedHostSecretsToml": {
      "description": "Secrets configuration for an allowed host.",
      "type": "object",
      "properties": {
        "env_vars": {
          "description": "Env vars using the same syntax as top-level `env_vars`.",
          "type": "array",
          "items": {
            "$ref": "#/$defs/EnvVarConfig"
          }
        },
        "replace_in": {
          "description": "Where in the request to perform replacement.\nDefault: empty (no replacement — deny by default).",
          "type": "array",
          "default": [],
          "items": {
            "$ref": "#/$defs/ReplaceIn"
          }
        }
      },
      "additionalProperties": false,
      "required": [
        "env_vars"
      ]
    },
    "AllowedHostToml": {
      "description": "An allowed outgoing HTTP host with optional method restrictions and secrets.",
      "type": "object",
      "properties": {
        "methods": {
          "description": "Allowed HTTP methods.\n- Omit to allow nothing (warning emitted).\n- `methods = \"*\"` or `methods = [\"*\"]` to allow all methods.\n- `methods = [\"GET\", \"POST\"]` to allow specific methods.\n- `methods = []` to allow nothing (warning emitted).",
          "anyOf": [
            {
              "$ref": "#/$defs/MethodsInput"
            },
            {
              "type": "null"
            }
          ]
        },
        "pattern": {
          "description": "Host pattern (e.g. `\"api.example.com\"`, `\"*.example.com\"`, `\"http://localhost:8080\"`).",
          "type": "string"
        },
        "secrets": {
          "description": "Optional secrets for this host.",
          "anyOf": [
            {
              "$ref": "#/$defs/AllowedHostSecretsToml"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "additionalProperties": false,
      "required": [
        "pattern"
      ]
    },
    "BlockingStrategyConfigCustomized": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "await"
            },
            "non_blocking_event_batching": {
              "type": "integer",
              "format": "uint32",
              "default": 100,
              "minimum": 0
            }
          },
          "additionalProperties": false,
          "required": [
            "kind"
          ]
        }
      ]
    },
    "BlockingStrategyConfigSimple": {
      "type": "string",
      "enum": [
        "interrupt",
        "await"
      ]
    },
    "BlockingStrategyConfigToml": {
      "anyOf": [
        {
          "$ref": "#/$defs/BlockingStrategyConfigCustomized"
        },
        {
          "$ref": "#/$defs/BlockingStrategyConfigSimple"
        }
      ]
    },
    "ComponentBacktraceConfig": {
      "type": "object",
      "properties": {
        "sources": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false,
      "required": [
        "sources"
      ]
    },
    "ComponentStdOutputToml": {
      "type": "string",
      "enum": [
        "none",
        "stdout",
        "stderr",
        "db"
      ]
    },
    "ConfigName": {
      "description": "Activity, Webhook, Workflow or a Http server",
      "type": "string"
    },
    "CronComponentConfigToml": {
      "type": "object",
      "properties": {
        "exec": {
          "$ref": "#/$defs/ExecConfigToml",
          "default": {
            "batch_size": 5,
            "lock_expiry": {
              "seconds": 1
            },
            "locking_strategy": null,
            "tick_sleep": {
              "milliseconds": 200
            }
          }
        },
        "ffqn": {
          "description": "Fully qualified function name of the target to invoke on each schedule tick.",
          "type": "string"
        },
        "name": {
          "$ref": "#/$defs/ConfigName"
        },
        "params": {
          "description": "JSON-encoded parameters to pass to the target function.",
          "type": "string",
          "default": "[]"
        },
        "schedule": {
          "description": "Cron expression or `@once`, `@daily`, `@hourly`, `@weekly`, `@monthly`, `@yearly`.",
          "type": "string"
        }
      },
      "additionalProperties": false,
      "required": [
        "name",
        "ffqn",
        "schedule"
      ]
    },
    "DurationConfig": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "milliseconds": {
              "type": "integer",
              "format": "uint64",
              "minimum": 0
            }
          },
          "additionalProperties": false,
          "required": [
            "milliseconds"
          ]
        },
        {
          "type": "object",
          "properties": {
            "seconds": {
              "type": "integer",
              "format": "uint64",
              "minimum": 0
            }
          },
          "additionalProperties": false,
          "required": [
            "seconds"
          ]
        },
        {
          "type": "object",
          "properties": {
            "minutes": {
              "type": "integer",
              "format": "uint64",
              "minimum": 0
            }
          },
          "additionalProperties": false,
          "required": [
            "minutes"
          ]
        },
        {
          "type": "object",
          "properties": {
            "hours": {
              "type": "integer",
              "format": "uint64",
              "minimum": 0
            }
          },
          "additionalProperties": false,
          "required": [
            "hours"
          ]
        }
      ]
    },
    "EnvVarConfig": {
      "anyOf": [
        {
          "description": "Forward from host: `\"KEY\"`",
          "type": "string"
        },
        {
          "description": "Set to value: `{key = \"KEY\", value = \"foo\"}` (supports `${VAR}` interpolation)",
          "type": "object",
          "properties": {
            "key": {
              "type": "string"
            },
            "value": {
              "type": "string"
            }
          },
          "required": [
            "key",
            "value"
          ]
        }
      ]
    },
    "ExecConfigToml": {
      "type": "object",
      "properties": {
        "batch_size": {
          "type": "integer",
          "format": "uint32",
          "default": 5,
          "minimum": 0
        },
        "lock_expiry": {
          "$ref": "#/$defs/DurationConfig",
          "default": {
            "seconds": 1
          }
        },
        "locking_strategy": {
          "anyOf": [
            {
              "$ref": "#/$defs/LockingStrategy"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "tick_sleep": {
          "$ref": "#/$defs/DurationConfig",
          "default": {
            "milliseconds": 200
          }
        }
      },
      "additionalProperties": false
    },
    "ExecProgramToml": {
      "description": "Program specification for exec activities (TOML input form).",
      "oneOf": [
        {
          "description": "Explicit argv. The first element is the executable; remaining elements are fixed arguments.\nActivity params are JSON-serialized and appended as trailing args.",
          "type": "object",
          "properties": {
            "external": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "additionalProperties": false,
          "required": [
            "external"
          ]
        },
        {
          "description": "Inline script content. Written to a temp file at each execution.\nActivity params are appended as args.",
          "type": "object",
          "properties": {
            "inline": {
              "type": "string"
            }
          },
          "additionalProperties": false,
          "required": [
            "inline"
          ]
        },
        {
          "description": "File path to include. Resolved to `inline` at canonicalization time.\nSupports `${DEPLOYMENT_DIR}/` prefix.",
          "type": "object",
          "properties": {
            "include": {
              "type": "string"
            }
          },
          "additionalProperties": false,
          "required": [
            "include"
          ]
        }
      ]
    },
    "ExecSecretsToml": {
      "description": "Secrets configuration for exec activities.",
      "type": "object",
      "properties": {
        "env_vars": {
          "description": "Secret entries resolved from environment variables.",
          "type": "array",
          "default": [],
          "items": {
            "$ref": "#/$defs/SecretEnvVarToml"
          }
        }
      },
      "additionalProperties": false
    },
    "JsLocationToml": {
      "description": "Location of a JavaScript source file.\nSupports local file paths and OCI registry references (`oci://...`).\nOn-disk format only; replaced by [`JsLocationCanonical`] before transmission and hash computation.",
      "type": "string"
    },
    "JsParamToml": {
      "description": "A parameter declaration for a JS activity function.",
      "type": "object",
      "properties": {
        "name": {
          "description": "Parameter name (used in WIT metadata).\nStored in kebab-case for WIT compatibility.",
          "type": "string"
        },
        "type": {
          "description": "WIT type string, e.g. `string`, `u32`, `list<string>`, `option<u64>`.",
          "type": "string"
        }
      },
      "additionalProperties": false,
      "required": [
        "name",
        "type"
      ]
    },
    "LockingStrategy": {
      "type": "string",
      "enum": [
        "by_ffqns",
        "by_component_digest"
      ]
    },
    "LogLevelToml": {
      "type": "string",
      "enum": [
        "off",
        "trace",
        "debug",
        "info",
        "warn",
        "error"
      ]
    },
    "MethodsInput": {
      "description": "Input for method restrictions in TOML configuration.\nSupports both `methods = \"*\"` and `methods = [\"GET\", \"POST\"]` syntax.",
      "anyOf": [
        {
          "description": "All methods allowed (from `methods = \"*\"`).",
          "$ref": "#/$defs/MethodsInputStar"
        },
        {
          "description": "Specific methods list (from `methods = [\"GET\", \"POST\"]`).",
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      ]
    },
    "MethodsInputStar": {
      "type": "null"
    },
    "ReplaceIn": {
      "description": "Where in the outgoing request placeholders are replaced.",
      "type": "string",
      "enum": [
        "headers",
        "body",
        "params"
      ]
    },
    "SecretEnvVarToml": {
      "description": "Secret entry: resolved from environment variables at startup.",
      "type": "object",
      "properties": {
        "name": {
          "description": "Name used to reference this secret in the `secrets.stdin` function.",
          "type": "string"
        },
        "value": {
          "description": "Value supporting `${VAR}` interpolation from host environment.",
          "type": "string",
          "default": ""
        }
      },
      "additionalProperties": false,
      "required": [
        "name"
      ]
    },
    "WebhookJsComponentConfigToml": {
      "type": "object",
      "properties": {
        "allowed_host": {
          "description": "Allowed outgoing HTTP hosts with optional method restrictions and secrets.",
          "type": "array",
          "default": [],
          "items": {
            "$ref": "#/$defs/AllowedHostToml"
          }
        },
        "content_digest": {
          "description": "Content digest of the JS source file.",
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "env_vars": {
          "type": "array",
          "default": [],
          "items": {
            "$ref": "#/$defs/EnvVarConfig"
          }
        },
        "forward_stderr": {
          "$ref": "#/$defs/ComponentStdOutputToml",
          "default": "db"
        },
